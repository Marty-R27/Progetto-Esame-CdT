   <text>
      <body>
         <pb n="1" xml:id="Farfalla_1877_4_8_90" facs="#Farfalla_1877_4_8_Pompei"/>
         <cb n="2" xml:id="col_2-p.90"/>
         <div type="intestazione">
            <head type="main" facs="#Farfalla_1877_4_8_90_titolo">Pompei</head>
            <metamark function="sectionDivider" facs="#Farfalla_1877_4_8_90_metamark1">~</metamark> 
            <head type="dedica" rend="uppercase" facs="#Farfalla_1877_4_8_90_dedica">(A <persName type="real" ref="coverlessListPerson.xml#ferdinandoFontana">FERDINANDO FONTANA</persName>)</head>
            <metamark function="sectionDivider" facs="#Farfalla_1877_4_8_90_metamark2">~</metamark>
         </div>
         <div type="text" facs="#Farfalla_1877_4_8_90_testo">
            <lg n="1" xml:id="lg_1" facs="#Farfalla_1877_4_8_90_lg1">
               <l n="1" xml:id="lg1_l1" facs="#Farfalla_1877_4_8_90_lg1_l1"><placeName type="real" ref="coverlessListPlace.xml#pompei">Pompei</placeName>, le <rs type="place" subtype="real" ref="coverlessListPlace.xml#pompei">tue</rs> macerie</l>
               <l n="2" xml:id="lg1_l2" facs="#Farfalla_1877_4_8_90_lg1_l2" rend="indent">Non <rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">mi</rs>&#160;<ref target="coverlessTassonomia.xml#anticonformismo">fanno paüra</ref>;</l>
               <l n="3" xml:id="lg1_l3" facs="#Farfalla_1877_4_8_90_lg1_l3" rend="indent"><ref target="coverlessTassonomia.xml#anticonformismo"><rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">Mi</rs> vien quasi da ridere</ref></l>
               <l n="4" xml:id="lg1_l4" facs="#Farfalla_1877_4_8_90_lg1_l4" rend="indent">Fra le <rs type="place" subtype="real" ref="coverlessListPlace.xml#pompei">tue</rs> vecchie mura...</l>
               <l n="5" xml:id="lg1_l5" facs="#Farfalla_1877_4_8_90_lg1_l5" rend="indent"><rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">Io</rs>&#160;<term type="verbum" subtype="studio_osservazione">guardo agli spettacoli</term></l>
               <l n="6" xml:id="lg1_l6" facs="#Farfalla_1877_4_8_90_lg1_l6" rend="indent">Della terra infinita,</l>
               <l n="7" xml:id="lg1_l7" facs="#Farfalla_1877_4_8_90_lg1_l7" rend="indent">Che un grido <rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">mi</rs> ripetono:</l>
               <l n="8" xml:id="lg1_l8" facs="#Farfalla_1877_4_8_90_lg1_l8" rend="indent"><q>Com'è bella la vita!</q></l>
            </lg>
            <lg n="2" xml:id="lg_2" facs="#Farfalla_1877_4_8_90_lg2">
               <l n="1" xml:id="lg2_l1" facs="#Farfalla_1877_4_8_90_lg2_l1"><ref target="coverlessTassonomia.xml#anticonformismo">Che <rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">m'</rs>importa</ref> se il sole</l>
               <l n="2" xml:id="lg2_l2" facs="#Farfalla_1877_4_8_90_lg2_l2" rend="indent"><term type="verbum" subtype="studio_osservazione">Risorga</term> e poi <term type="verbum" subtype="studio_osservazione">tramonti</term></l>
               <l n="3" xml:id="lg2_l3" facs="#Farfalla_1877_4_8_90_lg2_l3" rend="indent">Dalla <rs type="place" subtype="real" ref="coverlessListPlace.xml#pompei">tua</rs>&#160;<term type="verbum" subtype="arti_visive">gialla</term> mole</l>
               <l n="4" xml:id="lg2_l4" facs="#Farfalla_1877_4_8_90_lg2_l4" rend="indent">Dietro <term type="stile" subtype="lessico">grulli</term> orizzonti,</l>
               <l n="5" xml:id="lg2_l5" facs="#Farfalla_1877_4_8_90_lg2_l5" rend="indent">Mentre il serpe s'aggira</l>
               <l n="6" xml:id="lg2_l6" facs="#Farfalla_1877_4_8_90_lg2_l6" rend="indent">Fra le <rs type="place" subtype="real" ref="coverlessListPlace.xml#pompei">tue</rs> paci eterne</l>
               <l n="7" xml:id="lg2_l7" facs="#Farfalla_1877_4_8_90_lg2_l7" rend="indent">E ovunque l'<term type="verbum" subtype="studio_osservazione">occhio mira</term></l>
               <l n="8" xml:id="lg2_l8" facs="#Farfalla_1877_4_8_90_lg2_l8" rend="indent">Solo la pace <term type="verbum" subtype="studio_osservazione">scerne</term>?</l>
            </lg>
            <lg n="3" xml:id="lg_3" facs="#Farfalla_1877_4_8_90_lg3">
               <l n="1" xml:id="lg3_l1" facs="#Farfalla_1877_4_8_90_lg3_l1">In questo mondo <term type="verbum" subtype="vero_verita">scettico</term></l>
               <l n="2" xml:id="lg3_l2" facs="#Farfalla_1877_4_8_90_lg3_l2" rend="indent">Dove abbonda la noia</l>
               <l n="3" xml:id="lg3_l3" facs="#Farfalla_1877_4_8_90_lg3_l3" rend="indent">Dove il <ref target="coverlessTassonomia.xml#criticaLetteraria">pianto è rettorica</ref></l>
               <l n="4" xml:id="lg3_l4" facs="#Farfalla_1877_4_8_90_lg3_l4" rend="indent">Dove langue la gioia,</l>
               <l n="5" xml:id="lg3_l5" facs="#Farfalla_1877_4_8_90_lg3_l5" rend="indent">Vo' in cerca di qualcosa</l>
               <l n="6" xml:id="lg3_l6" facs="#Farfalla_1877_4_8_90_lg3_l6" rend="indent">Che somigli allo <ref target="coverlessTassonomia.xml#anticonformismo">strepito</ref>,</l>
               <l n="7" xml:id="lg3_l7" facs="#Farfalla_1877_4_8_90_lg3_l7" rend="indent">Che in mezzo a <ref target="coverlessTassonomia.xml#criticaLetteraria">tanta prosa</ref></l>
               <l n="8" xml:id="lg3_l8" facs="#Farfalla_1877_4_8_90_lg3_l8" rend="indent"><rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">Mi</rs> doni un pò di fremito!</l>
            </lg>
            <lg n="4" xml:id="lg_4" facs="#Farfalla_1877_4_8_90_lg4">
               <l n="1" xml:id="lg4_l1" facs="#Farfalla_1877_4_8_90_lg4_l1">E tutte <ref target="coverlessTassonomia.xml#anticonformismo">scatenatevi</ref></l>
               <l n="2" xml:id="lg4_l2" facs="#Farfalla_1877_4_8_90_lg4_l2" rend="indent"><ref target="coverlessTassonomia.xml#anticonformismo">Ire</ref> dei flutti <term type="verbum" subtype="arti_visive">azzurri</term></l>
               <l n="3" xml:id="lg4_l3" facs="#Farfalla_1877_4_8_90_lg4_l3" rend="indent">E intorno mormorate<rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">mi</rs></l>
               <l n="4" xml:id="lg4_l4" facs="#Farfalla_1877_4_8_90_lg4_l4" rend="indent">I feroci sussurri</l>
               <l n="5" xml:id="lg4_l5" facs="#Farfalla_1877_4_8_90_lg4_l5" rend="indent">Della tempesta, e fate</l>
               <l n="6" xml:id="lg4_l6" facs="#Farfalla_1877_4_8_90_lg4_l6" rend="indent">Che pari ad una <term type="stile" subtype="lessico">frasca</term></l>
               <l n="7" xml:id="lg4_l7" facs="#Farfalla_1877_4_8_90_lg4_l7" rend="indent"><rs type="person" subtype="real" ref="coverlessListPerson.xml#ignoto">Io</rs>&#160;<term type="verbum" subtype="evoluzione_sociale">sbatta</term> tra le ondate</l>
               <l n="8" xml:id="lg4_l8" facs="#Farfalla_1877_4_8_90_lg4_l8" rend="indent">Della vostra burrasca!</l>
            </lg>
         </div>
